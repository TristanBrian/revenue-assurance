# ============================================================================
# KPC REVENUE ASSURANCE – ENVIRONMENT VARIABLES
# ============================================================================

# --- Application ---
APP_NAME=KPC Revenue Assurance API
APP_VERSION=2.0.0
APP_ENV=development

# --- Database ---
# Read by backend/app/config.py from a .env file at the REPO ROOT (copy this file to .env here, not into backend/)
# PostgreSQL — REQUIRED if you want auth/RBAC to work: users/roles/permissions
# use Postgres-native UUID columns, unsupported by SQLite. Any Postgres
# instance works, doesn't have to be your system one (see AUTH_NOTES.md).
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/kpc_db
# SQLite (zero setup, but auth/RBAC tables can't be created against it —
# only reconciliation/e-billing/heatmap/graph/feed will work)
# DATABASE_URL=sqlite:///./kpc.db

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- KRA iCMS Simulation (E-Billing) ---
KRA_ICMS_ENDPOINT=https://api.kra.go.ke/icms/v2/invoices
KRA_ICMS_API_KEY=test-api-key-12345
KRA_ICMS_TIMEOUT=30

# --- Reconciliation ---
MATERIALITY_THRESHOLD=100000        # KSh – only flag leaks above this
CRITICAL_AGE_DAYS=60                # Days after which pending becomes critical

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# --- Security (REQUIRED — app/core/security.py reads SECRET_KEY directly
# from the environment and fails to import without it, not just in prod) ---
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60